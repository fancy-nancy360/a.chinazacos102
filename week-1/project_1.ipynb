   "source": [
    "# Simple Interest Program\n",
    "\n",
    "# input values\n",
    "P = float(input(\"Enter Principal: \"))\n",
    "R = float(input(\"Enter Rate (%): \"))\n",
    "T = float(input(\"Enter Time: \"))\n",
    "\n",
    "# calculation\n",
    "A = P * (1 + (R/100) * T)\n",
    "\n",
    "# output\n",
    "print(\"Amount =\", A)\n",
    "print(\"Data Type of Amount is\", type(A))"
   ]
  },
